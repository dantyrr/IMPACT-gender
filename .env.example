# PubMed
PUBMED_API_KEY=your_pubmed_api_key
PUBMED_EMAIL=your@email.com

# Cloudflare R2
# Account ID: shown on R2 overview page (32-char hex)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_BUCKET_NAME=impact-data
R2_PUBLIC_URL=https://pub-xxxx.r2.dev
# API token: created from My Profile → API Tokens (or R2 → Manage R2 API Tokens)
R2_SECRET_ACCESS_KEY=your_cloudflare_api_token
